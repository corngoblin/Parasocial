<?xml version="1.0" encoding="UTF-8"?>
<interface domain="twitchlive">
  <requires lib="gtk" version="4.0"/>

  <object class="GtkAdjustment" id="Adjust_Interval">
    <property name="lower">1</property>
    <property name="upper">30</property>
    <property name="step_increment">1</property>
  </object>

  <object class="GtkListStore" id="StreamSort_ListStore">
    <columns>
      <column type="gchararray"/>
      <column type="gchararray"/>
    </columns>
  </object>

  <object class="GtkListStore" id="TopBarDisplay_ListStore">
    <columns>
      <column type="gchararray"/>
      <column type="gchararray"/>
    </columns>
  </object>

  <!-- Twitch import dialog (for bulk-import) -->
  <object class="GtkDialog" id="UserPromptDialog">
    <property name="modal">1</property>
    <property name="use-header-bar">1</property>
    <child type="titlebar">
      <object class="GtkHeaderBar">
        <property name="can_focus">0</property>
        <property name="title-widget" translatable="yes">
          <object class="GtkLabel">
            <property name="label" translatable="yes">Import from twitch</property>
            <property name="hexpand">1</property>
            <property name="halign">1</property>
          </object>
        </property>
        <property name="hexpand">1</property>
      </object>
    </child>
    <child internal-child="content_area">
      <object class="GtkBox">
        <property name="visible">True</property>
        <property name="margin-start">10</property>
        <property name="margin-end">10</property>
        <property name="margin-top">10</property>
        <property name="margin-bottom">10</property>
        <property name="spacing">5</property>
        <child>
          <object class="GtkLabel">
            <property name="visible">True</property>
            <property name="label" translatable="yes">Twitch account to import follows from :</property>
            <property name="hexpand">1</property>
            <property name="halign">1</property>
          </object>
        </child>
        <child>
          <object class="GtkEntry" id="UserPromptDialog-entry">
            <property name="visible">True</property>
          </object>
        </child>
      </object>
    </child>
    <child type="action">
      <object class="GtkButton" id="UserPromptDialog-cancel">
        <property name="visible">True</property>
        <property name="label" translatable="yes">Cancel</property>
      </object>
    </child>
    <child type="action">
      <object class="GtkButton" id="UserPromptDialog-ok">
        <property name="visible">True</property>
        <property name="label" translatable="yes">Import</property>
      </object>
    </child>
    <action-widgets>
      <action-widget response="cancel">UserPromptDialog-cancel</action-widget>
      <action-widget response="ok" default="true">UserPromptDialog-ok</action-widget>
    </action-widgets>
  </object>

  <!-- Kick single-add dialog -->
  <object class="GtkDialog" id="KickStreamerDialog">
    <property name="modal">1</property>
    <property name="use-header-bar">1</property>
    <child type="titlebar">
      <object class="GtkHeaderBar">
        <property name="can_focus">0</property>
        <property name="title-widget" translatable="yes">
          <object class="GtkLabel">
            <property name="label" translatable="yes">Add Kick streamer</property>
            <property name="hexpand">1</property>
            <property name="halign">1</property>
          </object>
        </property>
        <property name="hexpand">1</property>
      </object>
    </child>
    <child internal-child="content_area">
      <object class="GtkBox">
        <property name="visible">True</property>
        <property name="margin-start">10</property>
        <property name="margin-end">10</property>
        <property name="margin-top">10</property>
        <property name="margin-bottom">10</property>
        <property name="spacing">5</property>
        <child>
          <object class="GtkLabel">
            <property name="visible">True</property>
            <property name="label" translatable="yes">Kick username:</property>
            <property name="hexpand">1</property>
            <property name="halign">1</property>
          </object>
        </child>
        <child>
          <object class="GtkEntry" id="KickStreamerDialog-entry">
            <property name="visible">True</property>
            <property name="activates-default">True</property>
          </object>
        </child>
      </object>
    </child>
    <child type="action">
      <object class="GtkButton" id="KickStreamerDialog-cancel">
        <property name="visible">True</property>
        <property name="label" translatable="yes">Cancel</property>
      </object>
    </child>
    <child type="action">
      <object class="GtkButton" id="KickStreamerDialog-ok">
        <property name="visible">True</property>
        <property name="label" translatable="yes">Add</property>
        <property name="has-default">True</property>
        <style>
          <class name="suggested-action"/>
        </style>
      </object>
    </child>
    <action-widgets>
      <action-widget response="cancel">KickStreamerDialog-cancel</action-widget>
      <action-widget response="ok" default="true">KickStreamerDialog-ok</action-widget>
    </action-widgets>
  </object>

  <!-- Twitch single-add dialog -->
  <object class="GtkDialog" id="TwitchStreamerDialog">
    <property name="modal">1</property>
    <property name="use-header-bar">1</property>
    <child type="titlebar">
      <object class="GtkHeaderBar">
        <property name="can_focus">0</property>
        <property name="title-widget" translatable="yes">
          <object class="GtkLabel">
            <property name="label" translatable="yes">Add Twitch streamer</property>
            <property name="hexpand">1</property>
            <property name="halign">1</property>
          </object>
        </property>
        <property name="hexpand">1</property>
      </object>
    </child>
    <child internal-child="content_area">
      <object class="GtkBox">
        <property name="visible">True</property>
        <property name="margin-start">10</property>
        <property name="margin-end">10</property>
        <property name="margin-top">10</property>
        <property name="margin-bottom">10</property>
        <property name="spacing">5</property>
        <child>
          <object class="GtkLabel">
            <property name="visible">True</property>
            <property name="label" translatable="yes">Twitch username:</property>
            <property name="hexpand">1</property>
            <property name="halign">1</property>
          </object>
        </child>
        <child>
          <object class="GtkEntry" id="TwitchStreamerDialog-entry">
            <property name="visible">True</property>
            <property name="activates-default">True</property>
          </object>
        </child>
      </object>
    </child>
    <child type="action">
      <object class="GtkButton" id="TwitchStreamerDialog-cancel">
        <property name="visible">True</property>
        <property name="label" translatable="yes">Cancel</property>
      </object>
    </child>
    <child type="action">
      <object class="GtkButton" id="TwitchStreamerDialog-ok">
        <property name="visible">True</property>
        <property name="label" translatable="yes">Add</property>
        <property name="has-default">True</property>
        <style>
          <class name="suggested-action"/>
        </style>
      </object>
    </child>
    <action-widgets>
      <action-widget response="cancel">TwitchStreamerDialog-cancel</action-widget>
      <action-widget response="ok" default="true">TwitchStreamerDialog-ok</action-widget>
    </action-widgets>
  </object>

  <!-- Main preferences widget -->
  <object class="GtkGrid" id="prefs-widget">
    <property name="visible">True</property>
    <property name="orientation">vertical</property>
    <child>
      <object class="GtkBox">
        <property name="visible">True</property>
        <property name="margin-start">10</property>
        <property name="margin-end">10</property>
        <property name="margin-top">10</property>
        <property name="margin-bottom">10</property>
        <property name="spacing">5</property>
        <child>
          <object class="GtkScrolledWindow" id="scrolledwindow1">
            <property name="visible">True</property>
            <property name="child">
              <object class="GtkTreeView" id="field_streamerslist">
                <property name="visible">True</property>
                <property name="hexpand">1</property>
                <property name="vexpand">1</property>
              </object>
            </property>
          </object>
        </child>
        <child>
          <object class="GtkGrid">
            <property name="visible">True</property>
            <property name="orientation">vertical</property>
            <child>
              <object class="GtkBox">
                <property name="visible">True</property>
                <property name="orientation">vertical</property>
                <child>
                  <object class="GtkButton" id="add_twitch_streamer">
                    <property name="visible">True</property>
                    <property name="label" translatable="yes">Add Twitch streamer</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="add_kick_streamer">
                    <property name="visible">True</property>
                    <property name="label" translatable="yes">Add Kick streamer</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="del_streamer">
                    <property name="visible">True</property>
                    <property name="label" translatable="yes">Remove selected</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="del_all_streamers">
                    <property name="visible">True</property>
                    <property name="label" translatable="yes">Remove all</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="import_from_twitch">
                    <property name="visible">True</property>
                    <property name="label" translatable="yes">Import from Twitch user</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="authenticate_oauth">
                    <property name="visible">True</property>
                    <property name="label" translatable="yes">OAuth authentication</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="refresh_icons">
                    <property name="visible">True</property>
                    <property name="label" translatable="yes">Refresh profile images</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>

    <child>
      <object class="GtkSeparator">
        <property name="visible">True</property>
      </object>
    </child>

    <child>
      <object class="GtkBox">
        <property name="visible">True</property>
        <property name="orientation">vertical</property>
        <property name="spacing">5</property>

        <!-- Topbar mode -->
        <child>
          <object class="GtkBox">
            <property name="visible">True</property>
            <property name="spacing">5</property>
            <child>
              <object class="GtkLabel">
                <property name="visible">True</property>
                <property translatable="yes" name="label">Panel display</property>
                <property name="hexpand">1</property>
                <property name="halign">1</property>
              </object>
            </child>
            <child>
              <object class="GtkComboBox" id="field_topbarmode">
                <property name="can_focus">0</property>
                <property name="model">TopBarDisplay_ListStore</property>
                <property name="id-column">0</property>
                <child>
                  <object class="GtkCellRendererText"/>
                  <attributes>
                    <attribute name="text">1</attribute>
                  </attributes>
                </child>
              </object>
            </child>
          </object>
        </child>

        <!-- Streamer notifications -->
        <child>
          <object class="GtkBox">
            <property name="visible">True</property>
            <property name="spacing">5</property>
            <child>
              <object class="GtkLabel">
                <property name="visible">True</property>
                <property name="label" translatable="yes">Streamer notifications</property>
                <property name="hexpand">1</property>
                <property name="halign">1</property>
              </object>
            </child>
            <child>
              <object class="GtkSwitch" id="field_notifications-enabled">
                <property name="visible">True</property>
              </object>
            </child>
          </object>
        </child>

        <child>
          <object class="GtkBox" id="obj_notifications-game-change">
            <property name="visible">True</property>
            <property name="spacing">5</property>
            <child>
              <object class="GtkLabel">
                <property name="visible">True</property>
                <property name="label" translatable="yes">Game change notifications</property>
                <property name="hexpand">1</property>
                <property name="halign">1</property>
              </object>
            </child>
            <child>
              <object class="GtkSwitch" id="field_notifications-game-change">
                <property name="visible">True</property>
              </object>
            </child>
          </object>
        </child>

        <child>
          <object class="GtkBox" id="obj_notifications-streamer-icon">
            <property name="visible">True</property>
            <property name="spacing">5</property>
            <child>
              <object class="GtkLabel">
                <property name="visible">True</property>
                <property name="label" translatable="yes">Show streamer icon on notifications</property>
                <property name="hexpand">1</property>
                <property name="halign">1</property>
              </object>
            </child>
            <child>
              <object class="GtkSwitch" id="field_notifications-streamer-icon">
                <property name="visible">True</property>
              </object>
            </child>
          </object>
        </child>

        <!-- Update interval -->
        <child>
          <object class="GtkBox">
            <property name="visible">True</property>
            <property name="spacing">5</property>
            <child>
              <object class="GtkLabel">
                <property name="visible">True</property>
                <property name="label" translatable="yes">Update Interval (min)</property>
                <property name="hexpand">1</property>
                <property name="halign">1</property>
              </object>
            </child>
            <child>
              <object class="GtkSpinButton" id="field_interval">
                <property name="visible">True</property>
                <property name="adjustment">Adjust_Interval</property>
              </object>
            </child>
          </object>
        </child>

        <!-- Twitch command -->
        <child>
          <object class="GtkBox">
            <property name="visible">True</property>
            <property name="orientation">vertical</property>
            <child>
              <object class="GtkLabel">
                <property name="visible">True</property>
                <property translatable="yes" name="label">Command to execute for Twitch streamers</property>
                <property name="hexpand">1</property>
                <property name="halign">1</property>
              </object>
            </child>
            <child>
              <object class="GtkEntry" id="field_opencmd">
                <property name="visible">True</property>
              </object>
            </child>
          </object>
        </child>

        <!-- Kick command -->
        <child>
          <object class="GtkBox">
            <property name="visible">True</property>
            <property name="orientation">vertical</property>
            <child>
              <object class="GtkLabel">
                <property name="visible">True</property>
                <property translatable="yes" name="label">Command to execute for Kick streamers</property>
                <property name="hexpand">1</property>
                <property name="halign">1</property>
              </object>
            </child>
            <child>
              <object class="GtkEntry" id="field_kickopencmd">
                <property name="visible">True</property>
              </object>
            </child>
          </object>
        </child>

        <!-- Hide playlist streams -->
        <child>
          <object class="GtkBox">
            <property name="visible">True</property>
            <property name="spacing">5</property>
            <child>
              <object class="GtkLabel">
                <property name="visible">True</property>
                <property translatable="yes" name="label">Hide playlist streams</property>
                <property name="hexpand">1</property>
                <property name="halign">1</property>
              </object>
            </child>
            <child>
              <object class="GtkSwitch" id="field_hideplaylists">
                <property name="visible">True</property>
              </object>
            </child>
          </object>
        </child>

        <!-- Hide indicator if empty -->
        <child>
          <object class="GtkBox">
            <property name="visible">True</property>
            <property name="spacing">5</property>
            <child>
              <object class="GtkLabel">
                <property name="visible">True</property>
                <property translatable="yes" name="label">Hide indicator if nobody is streaming</property>
                <property name="hexpand">1</property>
                <property name="halign">1</property>
              </object>
            </child>
            <child>
              <object class="GtkSwitch" id="field_hideempty">
                <property name="visible">True</property>
              </object>
            </child>
          </object>
        </child>

        <!-- Sort key -->
        <child>
          <object class="GtkBox">
            <property name="visible">True</property>
            <property name="spacing">5</property>
            <child>
              <object class="GtkLabel">
                <property name="visible">True</property>
                <property translatable="yes" name="label">Sort streamers by</property>
                <property name="hexpand">1</property>
                <property name="halign">1</property>
              </object>
            </child>
            <child>
              <object class="GtkComboBox" id="field_sortkey">
                <property name="can_focus">0</property>
                <property name="model">StreamSort_ListStore</property>
                <property name="id-column">0</property>
                <child>
                  <object class="GtkCellRendererText" id="renderer"/>
                  <attributes>
                    <attribute name="text">1</attribute>
                  </attributes>
                </child>
              </object>
            </child>
          </object>
        </child>

        <!-- Hide status -->
        <child>
          <object class="GtkBox">
            <property name="visible">True</property>
            <property name="spacing">5</property>
            <child>
              <object class="GtkLabel">
                <property name="visible">True</property>
                <property translatable="yes" name="label">Hide status line from the menu</property>
                <property name="hexpand">1</property>
                <property name="halign">1</property>
              </object>
            </child>
            <child>
              <object class="GtkSwitch" id="field_hidestatus">
                <property name="visible">True</property>
              </object>
            </child>
          </object>
        </child>

        <!-- Show uptime -->
        <child>
          <object class="GtkBox">
            <property name="visible">True</property>
            <property name="spacing">5</property>
            <child>
              <object class="GtkLabel">
                <property name="visible">True</property>
                <property translatable="yes" name="label">Show stream uptime</property>
                <property name="hexpand">1</property>
                <property name="halign">1</property>
              </object>
            </child>
            <child>
              <object class="GtkSwitch" id="field_showuptime">
                <property name="visible">True</property>
              </object>
            </child>
          </object>
        </child>

      </object>
    </child>
  </object>
</interface>
